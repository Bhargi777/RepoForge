# ============================================================================
# RepoForge AI Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values

# Groq API Configuration (Required for AI generation)
# Get your API key from: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Upstash Redis Configuration (Required for caching and rate limiting)
# Create a Redis database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token_here"

# GitHub Configuration (Required for repository metadata)
# Generate a Personal Access Token at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user, user:email
GITHUB_TOKEN="ghp_your_personal_access_token_here"

# NextAuth Configuration (Required for GitHub OAuth authentication)
# Get credentials from: https://github.com/settings/developers => OAuth Apps
GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# NextAuth Secret (Required for session encryption)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here_at_least_32_chars"

# NextAuth URL (Required for OAuth callback)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# OPTIONAL: GitHub OAuth Push Feature
# ============================================================================
# If you want to enable the "Push to GitHub" feature:
# 1. Create an OAuth App at https://github.com/settings/developers
# 2. Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
# 3. Copy the Client ID and Client Secret to GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET above
